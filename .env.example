# API Key Groq Anda (dari https://console.groq.com/keys)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Port server (Railway/Render mengisi ini otomatis, tidak perlu diubah)
PORT=3000

# URL frontend yang diizinkan mengakses backend ini
# Contoh: https://spmb-smkn4.netlify.app
FRONTEND_URL=https://spmb-smkn4.netlify.app
